.env
.env.*
!.env.example

# Local Docker/runtime state
backups/
tmp/
*.log
patches-*/

# Generated Node/Yarn/Twenty local state
**/node_modules/
**/.yarn/*
!**/.yarn/patches
!**/.yarn/plugins
!**/.yarn/releases
!**/.yarn/sdks
!**/.yarn/versions
**/.twenty/output/

# OS/editor files
.DS_Store
.idea/
.vscode/

# Sensitive exports and generated payloads
*.sql
*.dump
*.backup
*.pem
*.key
*.p12
*.pfx
*.crt

# LIXI/licensed or client-sensitive artifacts must not be committed.
licensed-lixi/
sample-payloads/
client-data/

# BrokerEngine/private operational captures must stay local or encrypted.
.brokerapp-private/
brokerengine-private/
private-template-imports/
private-screenshots/
*.private.json
*.private.ndjson
