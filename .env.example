# Twenty Docker image version.
# For first deployment, keep latest until we lock a tested release.
TAG=latest

# Public URL used by browsers and callbacks.
# Local first run:
SERVER_URL=http://localhost:3000

# Generate with:
# openssl rand -base64 32
APP_SECRET=replace_me_with_a_random_string

# Use a strong password without special characters for first Docker deployment.
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=replace_me_with_a_strong_password_without_special_characters
PG_DATABASE_HOST=db
PG_DATABASE_PORT=5432
PG_DATABASE_NAME=default

REDIS_URL=redis://redis:6379

# Local storage is acceptable for a first development deployment.
# For production, review S3/object storage and backup requirements.
STORAGE_TYPE=local
# STORAGE_S3_REGION=ap-southeast-2
# STORAGE_S3_NAME=
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# Optional email settings. Prefer configuring through the Twenty Admin Panel
# after first login unless infrastructure requires env-based configuration.
# EMAIL_FROM_ADDRESS=
# EMAIL_FROM_NAME=
# EMAIL_DRIVER=smtp
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=465
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=

# Optional identity/email/calendar integrations.
# Configure only after callback domains are final.
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_CALLBACK_URL=
# AUTH_GOOGLE_APIS_CALLBACK_URL=
# AUTH_MICROSOFT_ENABLED=
# AUTH_MICROSOFT_CLIENT_ID=
# AUTH_MICROSOFT_CLIENT_SECRET=
# AUTH_MICROSOFT_CALLBACK_URL=
# AUTH_MICROSOFT_APIS_CALLBACK_URL=

